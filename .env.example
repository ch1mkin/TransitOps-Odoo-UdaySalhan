# Supabase — copy from: Dashboard → Project Settings → API
#
# Project URL (no trailing slash)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
#
# anon public — paste ONLY the JWT (starts with eyJ...), not the variable name
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.paste-rest-of-anon-key-here
#
# service_role — server only, never expose in the browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.paste-your-service-role-key-here
